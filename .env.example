# Wistoria production environment template
# Copy relevant values into Vercel, Render, or local .env files.
# Never commit real secrets.

# Backend database
MONGODB_URI=
DATABASE_URL=

# Backend auth
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Backend CORS / public frontend URLs
CLIENT_URL=https://wistoria-abhisek-patels-projects.vercel.app
FRONTEND_URL=https://wistoria-abhisek-patels-projects.vercel.app

# Frontend API settings (Vite exposes only VITE_* values to the browser)
VITE_API_URL=https://wistoria-qq9f.onrender.com/api
VITE_API_BASE_URL=https://wistoria-qq9f.onrender.com/api

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
VITE_RAZORPAY_KEY_ID=

# Cloudinary (optional, only if uploads are enabled)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# NextAuth compatibility placeholders (not used by this Vite/Express app)
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://wistoria-abhisek-patels-projects.vercel.app
API_BASE_URL=https://wistoria-qq9f.onrender.com/api
